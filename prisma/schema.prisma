datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id    String @id @default(cuid())
  name  String
  email String @unique
  role  String @default("USER")
  cvs   Cv[]
}

model Skill {
  id          String @id @default(cuid())
  designation String
  cvs         Cv[]
}

model Cv {
  id     String  @id @default(cuid())
  name   String
  age    Int?
  job    String?
  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  skills Skill[]
}
